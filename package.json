{
  "name": "epmfinal",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "cds-plugin-ui5": "^0.17.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-epmm": "cds watch --open epmm/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-project1": "cds watch --open project1/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-project2": "cds watch --open project2/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/epmm",
    "app/project1",
    "app/project2"
  ],
  "cds": {
    "requires": {
      "auth": {
        "kind": "xsuaa",
        "[development]": {
          "kind": "mocked",
          "users": {
            "viewer": {
              "password": "viewer",
              "roles": ["Viewer"]
            },
            "manager": {
              "password": "manager",
              "roles": ["PurchaseManager", "Viewer"]
            },
            "admin": {
              "password": "admin",
              "roles": ["Administrator", "PurchaseManager", "Viewer"]
            },
             

            "alice": { "password": "pass", "roles": ["PurchaseManager"], "attr": { "Department": "Engineering" } },
            "bob": { "password": "pass", "roles": ["PurchaseManager"], "attr": { "Department": "Marketing" } },
            "carol": { "password": "pass", "roles": ["Viewer"] },
            "dave": { "password": "pass", "roles": ["Administrator"] },
            "eve": { "password": "pass", "roles": [] },





            "anonymous": {
              "password": "anon",
              "roles": []
              
            }
          }
        }
      }
    }
  }
}
